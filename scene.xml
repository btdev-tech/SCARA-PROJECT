<mujoco model="panda scene">
    <include file="scara_robot.xml"/>

    <statistic center="0.3 0 0.4" extent="1"/> <!-- This is to change view camera position -->

    <visual>
        <headlight diffuse="1 1 1" ambient="0.5 0.5 0.5" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="120" elevation="-20"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
        markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    </asset>

    <worldbody>
        <light pos="0 0 2" dir="0 0 -1" directional="true"/>
        <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
        
        <!--Table-->
        <body name="table" pos="-0.55 0 0.1">
            <geom type="box" size="0.2 0.2 0.1" rgba="0.8 0.6 0.4 1"/>
        </body>

        <!--Object-->
        <body name="object_to_pick" pos="-0.55 0 0.26">
            <joint type="free" />
            <geom name="box" type="box" size="0.05 0.05 0.05" solref="0.005 1" solimp="0.9 0.95 0.001" friction="2.0 2 0.005" rgba="1 0 0 0.5"/>
            <site name="box_pos" type="box" size="0.05 0.05 0.05"/>
        </body>
        <!--Goal-->
        <body name ="Goal_point_red" pos ="0.68 0 0.01">
            <geom type ="box" size ="0.1 0.1 0.01" rgba="1 0 0 1"/> 
            <geom type ="box" size ="0.1 0.01 0.06" pos="0 -0.1 0.05" rgba="1 0 0 0.5"/> 
            <geom type ="box" size ="0.1 0.01 0.06" pos="0 0.1 0.05" rgba="1 0 0 0.5"/>
            <geom type ="box" size ="0.01 0.1 0.06" pos="0.1 0 0.05" rgba="1 0 0 0.5"/>
            <geom type ="box" size ="0.01 0.1 0.06" pos="-0.1 0 0.05" rgba="1 0 0 0.5"/>
        </body>

        <body name ="Goal_point_green" pos ="0.48 0.4 0.01">
            <geom type ="box" size ="0.1 0.1 0.01" rgba="0 1 0 1"/> 
            <geom type ="box" size ="0.1 0.01 0.06" pos="0 -0.1 0.05" rgba="0 1 0 0.5"/>
            <geom type ="box" size ="0.1 0.01 0.06" pos="0 0.1 0.05" rgba="0 1 0 0.5"/>
            <geom type ="box" size ="0.01 0.1 0.06" pos="0.1 0 0.05" rgba="0 1 0 0.5"/>
            <geom type ="box" size ="0.01 0.1 0.06" pos="-0.1 0 0.05" rgba="0 1 0 0.5"/>
        </body>

        <body name ="Goal_point_blue" pos ="0.48 -0.4 0.01">
            <geom type ="box" size ="0.1 0.1 0.01" rgba="0 0 1 1"/> 
            <geom type ="box" size ="0.1 0.01 0.06" pos="0 -0.1 0.05" rgba="0 0 1 0.5"/>
            <geom type ="box" size ="0.1 0.01 0.06" pos="0 0.1 0.05" rgba="0 0 1 0.5"/>
            <geom type ="box" size ="0.01 0.1 0.06" pos="0.1 0 0.05" rgba="0 0 1 0.5"/>
            <geom type ="box" size ="0.01 0.1 0.06" pos="-0.1 0 0.05" rgba="0 0 1 0.5"/>
        </body>
        <camera name="top_view" pos="-0.55 0 1.2" xyaxes="1 0 0 0 1 0" fovy="20"/>
    </worldbody>
</mujoco>
