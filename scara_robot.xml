<mujoco model="scara_fix_collision">
    <compiler angle="radian" coordinate="local" inertiafromgeom="true" />
    <option gravity="0 0 -9.81" timestep="0.002" />

    <worldbody>
        <body name="base" pos="0 0 0.02">
            <geom type="box" size="0.08 0.08 0.02" rgba="1 0 0 1" />

            <body name="base_cylinder" pos="0 0 0.2">
                <geom type="cylinder" size="0.05 0.2" rgba="1 0 0 1" />

                <body name="disc_start 1" pos="0 0 0.2">
                    <joint name="joint1" type="hinge" axis="0 0 1" range="-3.14 3.14" limited="true" damping="50" armature="0.1" />
                    <geom type="cylinder" size="0.09 0.03" rgba="0.2 0.2 0.8 1" />

                    <body name="link_arm 1" pos="0.18 0 0">
                        <geom type="box" size="0.1 0.03 0.03" rgba="0.2 0.2 0.8 1" />

                        <body name="disc_end 1" pos="0.18 0 0">
                            <geom type="cylinder" size="0.09 0.03" rgba="0.2 0.2 0.8 1" />

                            <body name="disc_start 2" pos="0 0 0.06">
                                <joint name="joint2" type="hinge" axis="0 0 1" range="-2.8 2.8" limited="true" damping="50" armature="0.1" />
                                <geom type="cylinder" size="0.07 0.03" rgba="0 1 0 1" />

                                    <body name="link_arm 2" pos="0.16 0 0">
                                        <geom type="box" size="0.1 0.03 0.03" rgba="0 1 0 1" />

                                            <body name="disc_end 2" pos="0.16 0 0">
                                                <geom type="cylinder" size="0.07 0.03" rgba="0 1 0 1" />

                                                     <body name="z_cylinder" pos="0 0 0">
                                                        <joint name="joint3" type="slide" axis="0 0 1" range="-0.06 0.06" limited="true" damping="50" armature="0.1" />
                                                        <geom type="cylinder" size="0.02 0.1" rgba="1 1 1 1" />

                                                            <body name="vaccum_base" pos="0 0 -0.105">
                                                                <geom type="cylinder" size='0.03 0.005'
                                                                    rgba='0 0 0 1' />
                                                
                                                                    <body name="vaccum_plate" pos="0 0 -0.0065">
                                                                        <geom margin="0.05" gap="0.05" type="cylinder" size="0.05 0.006" solref="0.002 1" solimp="0.95 0.99 0.001" rgba="0 0 0 1" />

                                                                        <site name="touch_sensor_point" group="2" type="sphere" rgba="1 0 0 0.5" pos="0 0 -0.055" size="0.01" />
                                                                        <body name="vacuum_point">
                                                                            <geom name="p1" type="sphere" pos="0.04 0 -0.007" size="0.005" margin="0.04" gap="0.03" friction="2.0 2 0.005"/>                                                         
                                                                            <geom name="p2" type="sphere" pos="0.02 0.0346 -0.007" size="0.005" margin="0.04" gap="0.03" friction="2.0 2 0.005"/>                                                      
                                                                            <geom name="p3" type="sphere" pos="-0.02 0.0346 -0.007" size="0.005" margin="0.04" gap="0.03" friction="2.0 2 0.005"/>                                                   
                                                                            <geom name="p4" type="sphere" pos="-0.04 0 -0.007" size="0.005" margin="0.04" gap="0.03" friction="2.0 2 0.005"/>                                                 
                                                                            <geom name="p5" type="sphere" pos="-0.02 -0.0346 -0.007" size="0.005" margin="0.04" gap="0.03" friction="2.0 2 0.005"/>                                                    
                                                                            <geom name="p6" type="sphere" pos="0.02 -0.0346 -0.007" size="0.005" margin="0.04" gap="0.03" friction="2.0 2 0.005"/>
                                                                        </body>
                                                                </body>
                                                            </body>
                                                        </body>

                                                    </body>

                                                </body>

                                            </body>
                                        </body>
                                    </body>
                                </body>
                            </body>
                        </body>
                        
    </worldbody>

    <contact>
        <exclude body1="disc_end 2" body2="z_cylinder" />
        
    </contact>

    <actuator>
        <position name="joint1" joint="joint1" kp="500" />
        <position name="joint2" joint="joint2" kp="400" />
        <position name="joint3" joint="joint3" kp="1000" />
        <adhesion name="magnetic_gripper" body="vacuum_point" ctrlrange="0 100" gain="100"/>
    </actuator>
</mujoco>