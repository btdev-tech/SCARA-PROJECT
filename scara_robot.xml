            <body name="base_cylinder" pos="0 0 0.2">
                <geom type="cylinder" size="0.05 0.2" rgba="1 0 0 1"/>
                
                <body name="disc_start 1" pos="0 0 0.2">
                    <joint name="joint1" type="hinge" axis="0 0 1" range="-3.14 3.14" limited="true" damping="50" armature="0.1"/>
                    <geom type="cylinder" size="0.09 0.03" rgba="0.2 0.2 0.8 1" />
                        
                        <body name="link_arm 1" pos="0.18 0 0">
                            <geom  type="box" size="0.1 0.03 0.03" rgba="0.2 0.2 0.8 1"/>
                               
                                <body name="disc_end 1" pos="0.18 0 0">
                                    <geom type="cylinder" size="0.09 0.03" rgba="0.2 0.2 0.8 1"/>

                                        <body name="disc_start 2" pos="0 0 0.06">
                                            <joint name="joint2" type="hinge" axis="0 0 1" range="-2.8 2.8" limited="true" damping="50" armature="0.1"/>
                                            <geom type="cylinder" size="0.07 0.03" rgba="0 1 0 1"/>"

                                                <body name="link_arm 2" pos="0.16 0 0">
                                                    <geom type="box" size="0.1 0.03 0.03" rgba="0 1 0 1"/>"
                                                        
                                                        <body name="disc_end 2" pos="0.16 0 0">
                                                            <geom type="cylinder" size="0.07 0.03" rgba="0 1 0 1"/>

                                                                <body name ="z_cylinder" pos="0 0 0">
                                                                    <joint name="joint3" type="slide" axis="0 0 1" range="-0.06 0.06" limited="true" damping="50" armature="0.1" />
                                                                    <joint name="joint4" type="hinge" axis="0 0 1" range="-3.14 3.14" limited="true" damping="50" armature="0.1" />
                                                                    <geom type ="cylinder" size ="0.02 0.1" rgba="1 1 1 1"/>

                                                                        <body name="vaccum base" pos="0 0 -0.11">
                                                                            <geom type="cylinder" size='0.03 0.02' rgba='0 0 0 1'/>

                                                                                <body name="vaccum plate" pos="0 0 0.02">
                                                                                    <geom type="cylinder" size="0.05 0.005" rgba="1 1 1 1"/>
                                                                                </body>
                                                                        </body>
                                                                </body>

                                                        </body>
                                                    
                                                </body>

                                        </body>
                                </body>
                        </body>
                </body>
            </body>
        </body>
    </worldbody>

    <contact>
        <exclude body1="disc_end 2" body2="z_cylinder"/>
    </contact>

    <actuator>
        <position name="joint1" joint="joint1" kp="800"/>
        <position name="joint2" joint="joint2" kp="600"/>
        <position name="joint3" joint="joint3" kp="1000"/>
        <position name="joint4" joint="joint4" kp="400"/>
    </actuator>
</mujoco>